diff --git a/RunCPM/cpu1.h b/RunCPM/cpu1.h
index 0a9e3a5..0dbaab2 100644
--- a/RunCPM/cpu1.h
+++ b/RunCPM/cpu1.h
@@ -1032,7 +1032,16 @@ x == (C - 1) & 0xff for IND
 static inline void Z80reset(void) {
 	PC = 0;
 	IFF = 0;
+#ifdef __EMSCRIPTEN__
+	// Seed the refresh register R with browser entropy. Guests that seed their
+	// RNG from R (e.g. this CP/M Rogue port) would otherwise be identical every
+	// launch: RunCPM's boot path is deterministic and the keyboard wait parks in
+	// C (no Z80 instructions run, so R never advances while waiting). A random R
+	// per launch gives a fresh dungeon each run.
+	IR = (uint8)(emscripten_random() * 256.0);
+#else
 	IR = 0;
+#endif
 	Status = STATUS_RUNNING;
 	Debug = 0;
 	Step = -1;
@@ -1062,6 +1071,19 @@ static inline void Z80run(uint32 cpu_delay) {
 	/* main instruction fetch/decode loop */
 	while (!Status) {	/* loop until Status != 0 */
 
+#ifdef __EMSCRIPTEN__
+        /* Cooperative time-slicing for the browser. Console I/O yields via
+           ASYNCIFY, but a guest that runs a long stretch with no console call
+           (games generating a level, delay loops) would otherwise never return
+           to the event loop and would freeze the tab. Yield unconditionally
+           every N instructions so paint + keyboard keep working regardless of
+           what the guest does. */
+        {
+            static uint32 em_yield_cnt = 0;
+            if (++em_yield_cnt >= 250000) { em_yield_cnt = 0; emscripten_sleep(0); }
+        }
+#endif
+
         /* Throttling to CPU_DELAY instructions */
 		if (cpu_delay != 0) {
 	        if (++instr_cnt >= cpu_delay) {
